{
  "expo": {
    "name": "3310",
    "slug": "play3310",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "scheme": "play3310",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devbigeazi.play3310",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "splash": {
        "image": "./assets/icons/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0E27"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E27",
        "foregroundImage": "./assets/icons/splash-icon.png",
        "backgroundImage": "./assets/icons/splash-icon.png",
        "monochromeImage": "./assets/icons/splash-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bigeazi.play3310"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#0A0E27"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a390d93a-78fe-4a29-9bf9-8d0385ced1e5"
      }
    }
  }
}
